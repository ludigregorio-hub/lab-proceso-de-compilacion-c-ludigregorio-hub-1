      "name": "2. No hay #define en programa.i (macros expandidas)",
      "setup": "",
      "run": "test -f programa.i && ! grep -q '^#define' programa.i",
      "input": "", "output": "", "comparison": "included",
      "timeout": 10, "points": 3
